{
  "ci": {
    "collect": {
      "url": ["http://localhost:5173/", "http://localhost:5173/binance/chart"],
      "startServerCommand": "npm run dev",
      "startServerReadyPattern": "Local.*5173",
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

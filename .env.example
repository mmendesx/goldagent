# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_WEBSOCKET_STREAM_URL=wss://stream.binance.com:9443
BINANCE_WEBSOCKET_API_URL=wss://ws-api.binance.com:443/ws-api/v3

# Polymarket
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Trading
GOLD_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
GOLD_DEFAULT_INTERVAL=5m
GOLD_CONFIDENCE_THRESHOLD=70
GOLD_MAX_POSITIONS=3
GOLD_MAX_POSITION_SIZE_PERCENT=10
GOLD_MAX_DRAWDOWN_PERCENT=15
GOLD_DRY_RUN=true
GOLD_SENTIMENT_WEIGHT=0.3
GOLD_TRAILING_STOP_ATR_MULTIPLIER=1.0

# Indicator Parameters
GOLD_RSI_PERIOD=14
GOLD_MACD_FAST=12
GOLD_MACD_SLOW=26
GOLD_MACD_SIGNAL=9
GOLD_BOLLINGER_PERIOD=20
GOLD_BOLLINGER_STDDEV=2
GOLD_EMA_PERIODS=9,21,50,200
GOLD_ATR_PERIOD=14

# Infrastructure
GOLD_HTTP_PORT=8080
GOLD_DATABASE_URL=postgres://gold:gold@localhost:5432/gold?sslmode=disable
GOLD_REDIS_URL=redis://localhost:6379/0

# News / Sentiment
CRYPTOPANIC_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws/v1/stream
